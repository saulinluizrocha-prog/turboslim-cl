{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/thanks$",
      "status": 308,
      "headers": { "Location": "/thanks/" }
    },
    {
      "src": "/thanks/(.*)",
      "dest": "/thanks/$1"
    },
    {
      "src": "/thanks/?$",
      "dest": "/thanks/index.html"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf|eot|html))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
